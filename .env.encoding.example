# ── 인코딩 PC .env 템플릿 ─────────────────────────────────────────────────────
# 이 파일을 .env 로 복사한 뒤 실제 값을 채워 C:\rhoonart-encode\ 에 배치하세요.

# ── 폴더 경로 ────────────────────────────────────────────────────────────────
ENCODE_INPUT_DIR=C:\rhoonart-encode\input
ENCODE_OUTPUT_DIR=C:\rhoonart-encode\output
ENCODE_ERROR_DIR=C:\rhoonart-encode\_error

# ── Google ───────────────────────────────────────────────────────────────────
# Drive 다운로드/업로드용 서비스 계정 키 파일 경로
GOOGLE_SERVICE_ACCOUNT_FILE=C:\rhoonart-encode\credentials\service_account.json

# 인코딩 완료 파일을 업로드할 Google Drive 폴더 ID
# (Drive URL에서 /folders/XXXX 부분)
UPLOAD_DRIVE_FOLDER_ID=

# Gmail OAuth 자격증명 (처음 1회 브라우저 로그인 필요)
GMAIL_CREDENTIALS_FILE=C:\rhoonart-encode\credentials\gmail_oauth.json
GMAIL_TOKEN_FILE=C:\rhoonart-encode\credentials\gmail_token.json

# 메일 폴링 간격 (초, 기본 120)
GMAIL_POLL_INTERVAL=120

# ── Slack ────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_ENCODE_CHANNEL=#encoding-log

# ── AME ─────────────────────────────────────────────────────────────────────
AME_EXE_PATH=C:\Program Files\Adobe\Adobe Media Encoder 2024\Adobe Media Encoder.exe
# AME 프로세스 생존 확인 간격 (초, 기본 300)
AME_CHECK_INTERVAL=300

# ── 파일 기준 ────────────────────────────────────────────────────────────────
# 이 MB 이상이면 대용량 영상으로 판단 (기본 200)
LARGE_FILE_THRESHOLD_MB=200
# output 파일이 이 초 이상 변경 없으면 인코딩 완료로 판단 (기본 10)
OUTPUT_STABLE_SECONDS=10
