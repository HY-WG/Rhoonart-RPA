# ════════════════════════════════════════════════
#  루나트 RPA — 환경 변수 템플릿
#  .env.example → .env 로 복사 후 실제 값 입력
# ════════════════════════════════════════════════

# ── Google 인증 ────────────────────────────────
GOOGLE_CREDENTIALS_FILE=credentials.json

# ── 공통 시트 ID ───────────────────────────────
# 콘텐츠 관리 시트 (식별코드 목록 + 작품 관리)
CONTENT_SHEET_ID=1e-1JZ0eLnvMgpjAehpxRfPN2RiG6Pd22EidnnG8tmAvlKQ
# 성과 데이터 기록 시트 (비워두면 CONTENT_SHEET_ID 사용)
PERFORMANCE_SHEET_ID= 1JZ0eLnvMgpjAehpxRfPN2RiG6Pd22EidnnG8tmAvlKQ
# 로그 기록 시트 (비워두면 CONTENT_SHEET_ID 사용)
LOG_SHEET_ID= 1JZ0eLnvMgpjAehpxRfPN2RiG6Pd22EidnnG8tmAvlKQ

# ── 시트 탭명 ─────────────────────────────────
TAB_CONTENT=콘텐츠 목록
TAB_STATS=성과 관리
TAB_RIGHTS=작품 관리
TAB_LOG=로그 기록

# ── B-2: 주간 성과 보고 ────────────────────────
# Looker Studio 기본 대시보드 URL (권리사별 URL 없을 시 폴백)
LOOKER_URL_WAVVE=https://datastudio.google.com/reporting/a5fd405e-8e5c-44ab-a341-2e2782f3aa3a  # 웨이브×루나르트
LOOKER_URL_PANSCINEMA=https://datastudio.google.com/reporting/a5fd405e-8e5c-44ab-a341-2e2782f3aa3a    # 판씨네마×루나르트
LOOKER_URL_RIGHTS=https://datastudio.google.com/reporting/a5fd405e-8e5c-44ab-a341-2e2782f3aa3a   # 영상권리사×루나르트

# ── Slack ─────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_ERROR_CHANNEL=#rpa-error

# ── 이메일 발송 (AWS SES) ──────────────────────
SENDER_EMAIL=hoyoungy2@gmail.com
USE_SES=true
# SMTP 폴백 (USE_SES=false 일 때)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ── AWS ───────────────────────────────────────
AWS_REGION=ap-northeast-2

# ── A-3: 네이버 클립 월별 ──────────────────────
# 구글폼 응답이 연결된 스프레드시트 ID (응답 시트 탭명도 함께 설정)
NAVER_FORM_ID=1RDP-cf0fU9TAMEtTUZ_Av3d0Q-SjL59hULBPhiqouBs
NAVER_EXCEL_SHEET_ID=1sd1XKBQPnueYfCmFWZeejc2ltaonXEcWGY63aE22efQ
# 구글폼 응답 탭명 (기본값: "설문지 응답 시트1")
TAB_NAVER_FORM=설문지 응답 시트1
# 네이버 담당자 이메일 (엑셀 수신자)
NAVER_MANAGER_EMAIL= hoyoungy2@gmail.com
# 말일 Slack 확인 요청 채널 (기본값: SLACK_ERROR_CHANNEL)
NAVER_SLACK_CHANNEL=#naver-clip
# 폼 응답 컬럼명 오버라이드 (실제 폼 질문명과 다를 경우에만 입력)
# NAVER_COL_TIMESTAMP=타임스탬프
# NAVER_COL_CHANNEL_NAME=채널명
# NAVER_COL_CHANNEL_URL=채널 URL
# NAVER_COL_MANAGER_NAME=담당자명
# NAVER_COL_MANAGER_EMAIL=담당자 이메일
# NAVER_COL_GENRE=장르

# ── A-1: 카카오 알림톡 (미확인, 추후 입력) ────
# KAKAO_USER_ID=
# KAKAO_SENDER_PHONE=
# KAKAO_API_KEY=
# KAKAO_SENDER_KEY=

# ── C-1: 리드 발굴 (Playboard) ────────────────
# 리드 저장 시트 ID
LEAD_SHEET_ID= 1JZ0eLnvMgpjAehpxRfPN2RiG6Pd22EidnnG8tmAvlKQ
TAB_LEADS=리드
# 크롤링 대상 장르 (콤마 구분)
C1_GENRES=예능,드라마·영화
# 최소 월간 조회수 (기본 2,000만)
C1_MIN_MONTHLY_VIEWS=20000000
# 장르당 최대 크롤링 페이지
C1_MAX_PAGES=5


# ── C-2: 콜드메일 발송 ────────────────────────
# 발신자 이름 (메일 본문 서명에 표시)
SENDER_NAME=루나트
# 1회 실행당 최대 발송 수 (기본 50)
C2_BATCH_SIZE=50
# 최소 월간 조회수 필터 (기본 0 = 필터 없음)
C2_MIN_MONTHLY_VIEWS=0

# ── A-2: 어드민 API (미확인, 추후 입력) ────────
